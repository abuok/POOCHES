{
  "name": "gold-trading-system",
  "version": "1.0.0",
  "description": "Gold Trading Analysis System with TypeScript and Testing",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --ci",
    "test:python": "pytest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'ESLint not configured yet'",
    "lint:fix": "echo 'ESLint not configured yet'",
    "ci": "npm run typecheck && npm run test && npm run build",
    "predeploy": "npm run ci"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {},
  "keywords": [
    "trading",
    "gold",
    "xauusd",
    "analysis",
    "typescript"
  ],
  "author": "Trading System Developer",
  "license": "MIT"
}
